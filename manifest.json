{
  "manifest_version": 3,
  "name": "AtCoder Analytics",
  "version": "0.1.0",
  "description": "Adds graphs and an unsolved list to AtCoder user profile pages (powered by AtCoder Problems API).",
  "action": {
    "default_title": "AtCoder Analytics"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://atcoder.jp/users/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://kenkoooo.com/atcoder/*",
    "https://kenkoooo.com/atcoder/resources/*"
  ],
  "permissions": ["storage"]
}
